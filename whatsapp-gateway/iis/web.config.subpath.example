<?xml version="1.0" encoding="UTF-8"?>
<!--
  Use this when Angular calls https://your-domain.com/whatsapp-api/...
  Create an IIS Application at /whatsapp-api that uses this web.config.

  In Angular:
    whatsappApiUrl: 'https://your-domain.com/whatsapp-api'
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="WhatsApp API Subpath Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" appendQueryString="true" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_ACCEPT_ENCODING" value="" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
