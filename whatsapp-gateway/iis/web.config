<?xml version="1.0" encoding="UTF-8"?>
<!--
  Place this file in the IIS site / application root (NOT inside the Node app folder
  unless the IIS site points at this iis\ folder).

  Prerequisites:
  - IIS URL Rewrite Module
  - Application Request Routing (ARR) with "Enable proxy" checked
  - Node service running on http://127.0.0.1:3000
  - HTTPS binding + SSL certificate on this IIS site

  Angular / app URL example:
    https://your-domain.com/qr
    https://your-domain.com/events
    https://your-domain.com/send
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Reverse proxy all traffic to the local Node WhatsApp API -->
        <rule name="WhatsApp Node Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{CACHE_URL}" pattern="^(https?)://" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" appendQueryString="true" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_ACCEPT_ENCODING" value="" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Helpful for long-lived SSE (GET /events) -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <security>
      <requestFiltering>
        <!-- Allow longer requests if needed -->
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
